# OpenAI — analysiert die originale Webseite und erstellt den Stitch-Prompt
OPENAI_API_KEY=

# Stitch — generiert die mobile HTML-Seite aus dem OpenAI-Prompt
STITCH_API_KEY=
STITCH_API_URL=https://api.stitch.ai/v1/generate   # anpassen sobald Endpoint bekannt

# GitHub — erstellt Repo für jede generierte Seite (optional)
GITHUB_TOKEN=

# Vercel — deployed die Seite nach der Generierung (optional)
VERCEL_TOKEN=
VERCEL_TEAM_ID=

# URL auf die der QR-Code zeigt (deine deployed Admin-App)
NEXT_PUBLIC_MAIN_SITE_URL=http://localhost:3000
